# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# AI provider: "gemini" (has a free tier, recommended), "openai", or "anthropic"
AI_PROVIDER=gemini

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Batch processing tuning
AI_BATCH_SIZE=15
AI_MAX_CONCURRENCY=3
AI_MAX_RETRIES=2

MAX_CSV_SIZE_MB=10
